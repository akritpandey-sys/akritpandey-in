{
  "entities": {
    "Profile": {
      "title": "Founder Profile",
      "description": "Personal data and stats for Akrit Pandey",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "skills": { "type": "array" },
        "socialLinks": { "type": "object" },
        "achievements": { "type": "array" },
        "stats": {
          "type": "object",
          "properties": {
            "projectsCompleted": { "type": "number" },
            "activeProjects": { "type": "number" },
            "companyValuation": { "type": "number" },
            "teamSize": { "type": "number" }
          }
        }
      },
      "required": ["name", "role"]
    },
    "News": {
      "title": "News Feed Post",
      "description": "Instagram-style company updates and announcements",
      "type": "object",
      "properties": {
        "headline": { "type": "string" },
        "subheadline": { "type": "string" },
        "description": { "type": "string" },
        "imageUrls": { "type": "array" },
        "featuredImageUrl": { "type": "string" },
        "fileUrls": { "type": "array" },
        "videoUrls": { "type": "array" },
        "tags": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["headline", "description", "createdAt"]
    },
    "WikiPage": {
      "title": "Wikipedia Knowledge Base Page",
      "description": "Editable markdown content for company knowledge base",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["slug", "title", "content"]
    },
    "Project": {
      "title": "Company Project",
      "description": "Tracks project details, revenue, and status",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "client": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Pending"] },
        "teamMembers": { "type": "array" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      },
      "required": ["name", "value", "status"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Personnel tracking for Swaraj Digital",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "assignedProjects": { "type": "array" },
        "performance": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Finance": {
      "title": "Financial Report",
      "description": "Profit and Loss tracking per month",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "revenue": { "type": "number" },
        "expenses": { "type": "number" },
        "profit": { "type": "number" }
      },
      "required": ["month", "revenue", "expenses"]
    },
    "Job": {
      "title": "Job Posting",
      "description": "Position available at the company",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["Full-time", "Part-time", "Contract", "Internship"] },
        "description": { "type": "string" },
        "salary": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "requirements": { "type": "array" },
        "questions": { "type": "array" }
      },
      "required": ["title", "location", "type", "description", "status"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Candidate application for a job mission",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Reviewing", "Interviewing", "Accepted", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "answers": { "type": "object" }
      },
      "required": ["jobId", "userId", "userName", "userEmail", "resumeUrl", "status"]
    },
    "Message": {
      "title": "CRM Signal",
      "description": "Incoming message or contact request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "subject", "content", "read"]
    },
    "UserProfile": {
      "title": "User Identity",
      "description": "Sovereign identity node profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "employee"] },
        "bio": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "appliedJobs": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    }
  },
  "firestore": {
    "/profiles/{profileId}": {
      "schema": "Profile",
      "description": "Founder profile information"
    },
    "/news": {
      "schema": "News",
      "description": "Collection of company feed posts"
    },
    "/wiki": {
      "schema": "WikiPage",
      "description": "Wikipedia knowledge base pages"
    },
    "/projects": {
      "schema": "Project",
      "description": "Portfolio of company projects"
    },
    "/team": {
      "schema": "TeamMember",
      "description": "Team roster"
    },
    "/finance": {
      "schema": "Finance",
      "description": "Monthly financial records"
    },
    "/jobs": {
      "schema": "Job",
      "description": "Collection of available career nodes"
    },
    "/applications": {
      "schema": "Application",
      "description": "Registry of candidate applications"
    },
    "/messages": {
      "schema": "Message",
      "description": "Incoming signal streams"
    },
    "/users": {
      "schema": "UserProfile",
      "description": "Identity node profiles"
    }
  }
}
