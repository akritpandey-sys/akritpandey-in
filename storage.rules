rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media folder organized by user UID
    match /media/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == uid || 
        request.auth.token.email == 'shivashp77059@gmail.com'
      );
    }
    
    // Fallback for public assets
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'shivashp77059@gmail.com';
    }
  }
}
